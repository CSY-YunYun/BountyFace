    {
      "id": "RQZOK-V471wPWXVys-fxQ",
      "type": "text",
      "x": 86.02173490365101,
      "y": 1358.4050907133544,
      "width": 1171.9344482421875,
      "height": 2382.7028195813864,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
