      "seed": 2000160895,
      "version": 299,
      "versionNonce": 848919324,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782932851149,
      "link": null,
      "locked": false,
      "text": "Core Functionality : Cyberpunk-style facial scanner that detects individuals against a high-risk entity database to dynamically render gamified \"Threat Levels,\" \ncontextual danger titles, and safety risk attributes in real-time.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core Functionality : Cyberpunk-style facial scanner that detects individuals against a high-risk entity database to dynamically render gamified \"Threat Levels,\" \ncontextual danger titles, and safety risk attributes in real-time.",
      "autoResize": true,
      "lineHeight": 1.25
    },
