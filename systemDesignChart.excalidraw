      "updated": 1782975495629,
      "link": null,
      "locked": false,
      "text": "api design\n\nsend face embedding to server\nPOST /v1/scan\nbody: {\n\"faceEmbedding\": number[],\n}\n{\n  \"faceEmbedding\": [0.0123, -0.4567, 0.8912, ...512 maths...]\n}\nif the same info in database\nResponse\n{\n    \"status\": \"SUCCESS\",\n    \"matchFound\": true,\n    \"targetId\": \"uuid-v4-cool-string\",\n    \"message\": \"Target identified successfully.\"\n}\nif doesn't have info in database, will make new info\nResponse:\n{\n    \"status\": \"SUCCESS\",\n    \"matchFound\": false,\n    \"message\": \"New face detected. Please create a profile.\"\n}\n\nif face is the same in database, receive info\nPOST /v1/scan\nResponse:\n{\n    \"status\": \"SUCCESS\",\n    \"matchFound\": true,\n    \"lastUpdated\"\n    \"profile\": {\n        \"codename\": \"黑曜石\",\n        \"threat_level\": \"S\",\n        \"power_level\": 9000,\n        \"net_worth\": 50000000,\n        \"hacking\": 85,\n        \"stealth\": 90,\n        \"description\": \"該目標常出沒於霓虹街區底層，擅長使用未知協定黑入企業級防火牆。\",\n        \"is_public_figure\": false\n    }\n}\n\nmake new info in server and save info to database\nPOST /v1/targets/save\nbody:{\n  \"profile\": {\n        \"face_embedding\" (特徵向量)\n        \"codename\" (稱號)\n        \"threat_level\" (威脅等級)\n        \"power_level\" (戰鬥力)\n        \"net_worth\" (財力)\n        \"hacking\" (黑客)\n        \"stealth\" (潛行)\n        \"description\" (背景描述)\n        \"description\": \"該目標常出沒於霓虹街區底層，擅長使用未知協定黑入企業級防火牆。\"\n        \"is_public_figure\" (公眾人物標記)\n        \"lastUpdated\"\n    },\n}\nResponse:\n{\n  \"status\": \"SUCCESS\",\n  \"message\": \"New target saved successfully.\"\n}\n   ",
      "fontSize": 28.031797877428072,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "api design\n\nsend face embedding to server\nPOST /v1/scan\nbody: {\n\"faceEmbedding\": number[],\n}\n{\n  \"faceEmbedding\": [0.0123, -0.4567, 0.8912, ...512 maths...]\n}\nif the same info in database\nResponse\n{\n    \"status\": \"SUCCESS\",\n    \"matchFound\": true,\n    \"targetId\": \"uuid-v4-cool-string\",\n    \"message\": \"Target identified successfully.\"\n}\nif doesn't have info in database, will make new info\nResponse:\n{\n    \"status\": \"SUCCESS\",\n    \"matchFound\": false,\n    \"message\": \"New face detected. Please create a profile.\"\n}\n\nif face is the same in database, receive info\nPOST /v1/scan\nResponse:\n{\n    \"status\": \"SUCCESS\",\n    \"matchFound\": true,\n    \"lastUpdated\"\n    \"profile\": {\n        \"codename\": \"黑曜石\",\n        \"threat_level\": \"S\",\n        \"power_level\": 9000,\n        \"net_worth\": 50000000,\n        \"hacking\": 85,\n        \"stealth\": 90,\n        \"description\": \"該目標常出沒於霓虹街區底層，擅長使用未知協定黑入企業級防火牆。\",\n        \"is_public_figure\": false\n    }\n}\n\nmake new info in server and save info to database\nPOST /v1/targets/save\nbody:{\n  \"profile\": {\n        \"face_embedding\" (特徵向量)\n        \"codename\" (稱號)\n        \"threat_level\" (威脅等級)\n        \"power_level\" (戰鬥力)\n        \"net_worth\" (財力)\n        \"hacking\" (黑客)\n        \"stealth\" (潛行)\n        \"description\" (背景描述)\n        \"description\": \"該目標常出沒於霓虹街區底層，擅長使用未知協定黑入企業級防火牆。\"\n        \"is_public_figure\" (公眾人物標記)\n        \"lastUpdated\"\n    },\n}\nResponse:\n{\n  \"status\": \"SUCCESS\",\n  \"message\": \"New target saved successfully.\"\n}\n   ",
      "autoResize": true,
      "lineHeight": 1.25
    },
