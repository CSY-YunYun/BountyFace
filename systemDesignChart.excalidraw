    {
      "id": "pXAQ-JQPcXLD5xfvtWWTh",
      "type": "text",
      "x": 37.453270533259854,
      "y": 390.74990651917045,
      "width": 2037.390869140625,
      "height": 910,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
